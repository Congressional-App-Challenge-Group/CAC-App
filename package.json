{
  "name": "civiclens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "pnpm install",
    "dev": "pnpm ingest:local && next dev",
    "build": "pnpm ingest:local && next build",
    "serve": "pnpm build && pnpm start",
    "start": "next start",
    "lint": "next lint",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:local": "tsx scripts/ingest-local.ts",
    "ingest:publish": "AUTO_PUBLISH_INGESTION=true tsx scripts/ingest.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.33.0"
}
